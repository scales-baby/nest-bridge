    "test": "node test/crypto-roundtrip.mjs",
    "pack:mcpb": "bash scripts/pack-mcpb.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "hash-wasm": "^4.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
